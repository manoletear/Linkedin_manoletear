# LLM Providers (at least one required)
# Groq: https://console.groq.com (free, 30 RPM, 14.4K req/day)
GROQ_API_KEY=gsk_...
# Cerebras: https://console.cerebras.ai (free, 1M tokens/day)
CEREBRAS_API_KEY=csk-...

# LinkedIn OAuth 2.0
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:your_person_id

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini (Google AI Studio - free at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# RSS Feeds (comma-separated)
RSS_FEEDS=https://feeds.feedburner.com/TechCrunch,https://www.wired.com/feed/rss

# Agent config
DEFAULT_SECTOR=technology
DEFAULT_LANGUAGE=es
LOG_LEVEL=info
