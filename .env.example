# LinkedIn API Credentials
# Obtén tus credenciales en: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=tu_access_token_aqui

# Anthropic API Key
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=tu_api_key_aqui

# Configuración del agente
POST_LANGUAGE=es
POST_TONE=profesional

# Configuración de TooxsLkdn
# Hora de publicación diaria (formato HH:MM)
POST_TIME=09:00
# Modo prueba: true = genera posts pero no los publica
DRY_RUN=true

# ===== TooxsRedactor (Agente de Redacción) =====

# Stability AI - Generación de imágenes (opcional, económico)
# Obtén tu API key en: https://platform.stability.ai/
STABILITY_API_KEY=tu_stability_key_aqui

# Ruta al archivo de personalidad de Manuel Aravena
PERSONALITY_PATH=config/Manuel Aravena.md

# ===== TooxsNews (Agente de Noticias) =====

# Google Sheets - Credenciales de Service Account
# Descarga el JSON desde: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_CREDENTIALS_PATH=config/credentials.json
# ID del spreadsheet (lo encuentras en la URL de tu Google Sheet)
GOOGLE_SPREADSHEET_ID=tu_spreadsheet_id_aqui

# APIs de búsqueda de noticias (opcionales, Google News RSS es gratis)
# Serper (Google Search API): https://serper.dev/
SERPER_API_KEY=tu_serper_key_aqui
# NewsAPI: https://newsapi.org/
NEWSAPI_KEY=tu_newsapi_key_aqui
