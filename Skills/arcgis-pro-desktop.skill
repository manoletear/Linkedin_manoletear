## 4. Python y ArcPy en ArcGIS Pro

### ArcPy - API de Python para ArcGIS

```python
import arcpy

# Configurar workspace
arcpy.env.workspace = r"C:\data\myproject.gdb"
arcpy.env.overwriteOutput = True

# Ejecutar herramienta de geoprocessing
arcpy.analysis.Buffer(
    in_features="cities",
    out_feature_class="cities_buffer",
    buffer_distance_or_field="10 Kilometers"
)

# Query con cursor
with arcpy.da.SearchCursor("cities", ["NAME", "POPULATION", "SHAPE@XY"]) as cursor:
    for row in cursor:
        print(f"{row[0]}: {row[1]} - ({row[2][0]}, {row[2][1]})")

# Editar con cursor
with arcpy.da.UpdateCursor("cities", ["POPULATION"]) as cursor:
    for row in cursor:
        row[0] = row[0] * 1.05  # Incrementar 5%
        cursor.updateRow(row)

# Insertar features
with arcpy.da.InsertCursor("cities", ["NAME", "POPULATION", "SHAPE@XY"]) as cursor:
    cursor.insertRow(["New City", 50000, (-117.19, 34.05)])
```

### Módulos de ArcPy:

#### arcpy.da (Data Access)
```python
# Cursores de alto rendimiento
arcpy.da.SearchCursor(dataset, fields, where_clause, spatial_reference)
arcpy.da.UpdateCursor(dataset, fields, where_clause)
arcpy.da.InsertCursor(dataset, fields)

# Tokens de geometría: SHAPE@, SHAPE@XY, SHAPE@TRUECENTROID, SHAPE@X, SHAPE@Y,
# SHAPE@Z, SHAPE@M, SHAPE@JSON, SHAPE@WKB, SHAPE@WKT, SHAPE@AREA, SHAPE@LENGTH
# OID@, GLOBALID@
```

#### arcpy.mp (Mapping)
```python
# Trabajar con proyectos, mapas y layouts
aprx = arcpy.mp.ArcGISProject(r"C:\projects\myproject.aprx")
map = aprx.listMaps("Map")[0]
layers = map.listLayers()
layout = aprx.listLayouts("Layout")[0]

# Exportar
layout.exportToPDF(r"C:\output\map.pdf")
layout.exportToPNG(r"C:\output\map.png")

# Publicar
map.getWebLayerSharingDraft("HOSTING_SERVER", "FEATURE", "My Layer")
```

#### arcpy.management (Gestión de datos)
```python
arcpy.management.CreateFileGDB(r"C:\data", "output.gdb")
arcpy.management.AddField("cities", "NEW_FIELD", "DOUBLE")
arcpy.management.CalculateField("cities", "NEW_FIELD", "!POPULATION! * 2", "PYTHON3")
arcpy.management.Project("cities", "cities_projected", arcpy.SpatialReference(4326))
arcpy.management.CopyFeatures("cities", r"C:\data\output.gdb\cities_copy")
```

#### arcpy.conversion
```python
arcpy.conversion.FeatureClassToShapefile("cities", r"C:\output")
arcpy.conversion.JSONToFeatures(r"data.json", "output_features")
arcpy.conversion.TableToExcel("cities", r"C:\output\cities.xlsx")
```

#### arcpy.analysis
```python
arcpy.analysis.Buffer("cities", "cities_buf", "5 Kilometers")
arcpy.analysis.Intersect(["layer1", "layer2"], "intersection")
arcpy.analysis.SpatialJoin("points", "polygons", "points_joined")
arcpy.analysis.Near("cities", "rivers")
```

### Script Tools:
```python
# Definir parámetros de herramienta
import arcpy

# Obtener parámetros
input_fc = arcpy.GetParameterAsText(0)
buffer_dist = arcpy.GetParameterAsText(1)
output_fc = arcpy.GetParameterAsText(2)

# Mensajes de progreso
arcpy.AddMessage("Procesando buffer...")
arcpy.SetProgressor("step", "Ejecutando análisis...", 0, 100, 10)

# Ejecutar
arcpy.analysis.Buffer(input_fc, output_fc, buffer_dist)

# Establecer output
arcpy.SetParameterAsText(2, output_fc)
arcpy.AddMessage("Proceso completado exitosamente.")
```

### Python Toolboxes (.pyt):
```python
import arcpy

class Toolbox:
    def __init__(self):
        self.label = "Mi Toolbox"
        self.alias = "miToolbox"
        self.tools = [MiHerramienta]

class MiHerramienta:
    def __init__(self):
        self.label = "Mi Herramienta"
        self.description = "Descripción de la herramienta"
        self.canRunInBackground = True

    def getParameterInfo(self):
        param0 = arcpy.Parameter(
            displayName="Input Features",
            name="in_features",
            datatype="GPFeatureLayer",
            parameterType="Required",
            direction="Input"
        )
        return [param0]

    def execute(self, parameters, messages):
        in_features = parameters[0].valueAsText
        arcpy.AddMessage(f"Procesando: {in_features}")
        # ... lógica aquí
```

