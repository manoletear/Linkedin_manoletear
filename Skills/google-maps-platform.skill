## 11. Client Libraries

```bash
# Node.js
npm install @googlemaps/google-maps-services-js

# Python
pip install googlemaps

# Go
go get googlemaps.github.io/maps

# Java
<dependency>
  <groupId>com.google.maps</groupId>
  <artifactId>google-maps-services</artifactId>
</dependency>
```

### Python Client:
```python
import googlemaps

gmaps = googlemaps.Client(key="API_KEY")

# Geocoding
result = gmaps.geocode("Av Kennedy 7100, Vitacura, Chile")
lat = result[0]["geometry"]["location"]["lat"]
lng = result[0]["geometry"]["location"]["lng"]

# Reverse geocoding
result = gmaps.reverse_geocode((-33.4078, -70.5755))

# Directions
directions = gmaps.directions("Santiago, Chile", "Valparaíso, Chile",
                               mode="driving", language="es")

# Distance Matrix
matrix = gmaps.distance_matrix(
    origins=["Santiago, Chile"],
    destinations=["Valparaíso, Chile", "Viña del Mar, Chile"],
    mode="driving", language="es"
)

# Elevation
elevation = gmaps.elevation((-33.4078, -70.5755))

# Places
places = gmaps.places_nearby(
    location=(-33.4078, -70.5755),
    radius=1000, type="restaurant"
)
```

