## 2. SUPABASE - Base de Datos y Backend

### Herramientas disponibles:
- `execute_sql` - Ejecutar consultas SQL
- `list_tables` - Listar tablas
- `apply_migration` - Aplicar migraciones
- `deploy_edge_function` - Desplegar funciones serverless
- `get_logs` - Ver logs de la aplicación
- `list_projects` - Listar proyectos
- `create_project` - Crear proyecto nuevo

### Esquema propuesto para RETaxes:

```sql
-- Propiedades
CREATE TABLE properties (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    address TEXT NOT NULL,
    commune TEXT NOT NULL,
    region TEXT DEFAULT 'Metropolitana',
    latitude DOUBLE PRECISION,
    longitude DOUBLE PRECISION,
    lot_area_m2 NUMERIC,
    built_area_m2 NUMERIC,
    floors INTEGER,
    year_built INTEGER,
    zoning_code TEXT,          -- Ej: "E-Am4", "Zona SC"
    land_use TEXT,             -- Ej: "Residencial", "Mixto"
    max_height_m NUMERIC,
    max_floors INTEGER,
    constructibility_coef NUMERIC,
    soil_occupation_coef NUMERIC,
    tax_appraisal_clf NUMERIC, -- Avalúo fiscal en CLF (UF)
    commercial_value_clf NUMERIC,
    owner_id UUID REFERENCES owners(id),
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Propietarios
CREATE TABLE owners (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    rut TEXT UNIQUE,
    name TEXT NOT NULL,
    email TEXT,
    phone TEXT,
    hubspot_contact_id TEXT,
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Tasaciones
CREATE TABLE appraisals (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    property_id UUID REFERENCES properties(id),
    appraiser_id UUID,
    appraisal_date DATE,
    commercial_value_clf NUMERIC,
    tax_value_clf NUMERIC,
    method TEXT,               -- "Comparación", "Costo", "Renta"
    status TEXT DEFAULT 'pending', -- pending, in_progress, completed
    report_url TEXT,
    notes TEXT,
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Contribuciones (impuestos territoriales)
CREATE TABLE tax_contributions (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    property_id UUID REFERENCES properties(id),
    year INTEGER,
    quarter INTEGER,          -- 1,2,3,4
    amount_clp BIGINT,
    due_date DATE,
    paid BOOLEAN DEFAULT FALSE,
    paid_date DATE,
    receipt_number TEXT,
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Zonas PRC por comuna
CREATE TABLE prc_zones (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    commune TEXT NOT NULL,
    zone_code TEXT NOT NULL,
    zone_name TEXT,
    land_uses_permitted TEXT[],
    land_uses_prohibited TEXT[],
    max_height_m NUMERIC,
    max_floors INTEGER,
    constructibility_coef NUMERIC,
    soil_occupation_coef NUMERIC,
    max_density_hab_ha NUMERIC,
    min_lot_area_m2 NUMERIC,
    setback_m NUMERIC,
    building_type TEXT,        -- "Aislada", "Pareada", "Continua"
    source_url TEXT,
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Índices espaciales (PostGIS)
-- ALTER TABLE properties ADD COLUMN geom GEOMETRY(Point, 4326);
-- CREATE INDEX idx_properties_geom ON properties USING GIST(geom);
```

### Edge Functions para cálculos:

```typescript
// supabase/functions/calculate-tax/index.ts
import { serve } from "https://deno.land/std/http/server.ts";

serve(async (req) => {
  const { property_id, appraisal_value_uf } = await req.json();

  // Tabla de tasas de contribuciones Chile (SII)
  // Tramo 1: 0-670 UF exento
  // Tramo 2: 670-3,356 UF tasa 0.98%
  // Tramo 3: 3,356-6,713 UF tasa 1.143%
  // Tramo 4: >6,713 UF tasa 1.306%

  let annual_tax_uf = 0;
  if (appraisal_value_uf <= 670) {
    annual_tax_uf = 0;
  } else if (appraisal_value_uf <= 3356) {
    annual_tax_uf = (appraisal_value_uf - 670) * 0.0098;
  } else if (appraisal_value_uf <= 6713) {
    annual_tax_uf = (3356 - 670) * 0.0098 + (appraisal_value_uf - 3356) * 0.01143;
  } else {
    annual_tax_uf = (3356 - 670) * 0.0098 + (6713 - 3356) * 0.01143
                  + (appraisal_value_uf - 6713) * 0.01306;
  }

  const quarterly_tax_uf = annual_tax_uf / 4;

  return new Response(JSON.stringify({
    appraisal_value_uf,
    annual_tax_uf: Math.round(annual_tax_uf * 100) / 100,
    quarterly_tax_uf: Math.round(quarterly_tax_uf * 100) / 100,
    exempt: appraisal_value_uf <= 670
  }));
});
```

